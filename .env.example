# ── Backend environment variables ────────────────────────────────────────────
# Copy this file to ".env" for local use, or set these in your host's dashboard.

# Port the server listens on. Hosts like Render set this automatically.
PORT=3000

# Comma-separated list of allowed frontend origins (CORS).
# Local dev:
CORS_ORIGINS=http://localhost:5173
# Production example (your GitHub Pages URL — no trailing slash):
# CORS_ORIGINS=https://yourname.github.io

# Secret used to sign JWT tokens. MUST be a long random string in production.
JWT_SECRET=change-this-to-a-long-random-secret
